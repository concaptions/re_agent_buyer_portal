# Copy to .env and fill in. .env is gitignored.

# Flask session signing key. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Baserow API token with read on the buyer table and read+write on the agent table.
# Rotate via baserow.intevoai.com → Settings → API tokens.
BASEROW_TOKEN=

# Override these only if the Baserow workspace / table IDs change.
BASEROW_BUYER_TABLE_URL=https://baserow.intevoai.com/api/database/rows/table/684/
BASEROW_AGENT_TABLE_URL=https://baserow.intevoai.com/api/database/rows/table/687/

# Telegram bot the signup wizard hands agents off to (no @ prefix).
TELEGRAM_BOT_USERNAME=reagent512_bot
